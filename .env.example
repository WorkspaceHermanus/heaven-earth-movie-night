# ---------------------------------------------------------------------------
# Database (Neon or Supabase — Postgres)
# ---------------------------------------------------------------------------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct (non-pooled) connection, used by `prisma migrate`. On Neon this is the
# same host without `-pooler`; on Supabase use the port 5432 connection string.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ---------------------------------------------------------------------------
# Yoco (https://portal.yoco.com → Sell Online → Payment Gateway)
# ---------------------------------------------------------------------------
# Use sk_test_... while testing, sk_live_... in production.
YOCO_SECRET_KEY="sk_test_YOUR_YOCO_TEST_KEY_HERE"
# From the webhook you create pointing at /api/webhooks/yoco
YOCO_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET_HERE"

# ---------------------------------------------------------------------------
# Resend (https://resend.com/api-keys)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_RESEND_API_KEY_HERE"
# Must be a verified domain in Resend. Falls back to Resend's test sender.
RESEND_FROM_EMAIL="Heaven & Earth Hermanus <bookings@yourdomain.co.za>"

# ---------------------------------------------------------------------------
# Admin dashboard
# ---------------------------------------------------------------------------
ADMIN_PASSWORD="choose-a-long-random-password"
# Random string, at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="YOUR_64_HEX_CHARACTERS_HERE"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public origin, no trailing slash. Vercel fills this in automatically if you
# leave it unset, but set it explicitly once you attach a custom domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
